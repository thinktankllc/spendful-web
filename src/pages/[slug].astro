---
import Layout from '@/layouts/main.astro'
import {
  SEO_LANDING_PAGES,
  SITE,
  absoluteUrl,
  makeBreadcrumbSchema,
  makeFAQSchema,
  makeMobileApplicationSchema,
  makeWebPageSchema,
} from '@/lib/seo'

export function getStaticPaths() {
  return SEO_LANDING_PAGES.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }))
}

const { page } = Astro.props
const path = `/${page.slug}/`
const schema = [
  makeWebPageSchema({
    title: page.title,
    description: page.description,
    path,
  }),
  makeBreadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: page.title, path },
  ]),
  makeFAQSchema(page.faq),
  makeMobileApplicationSchema(),
]
---

<Layout title={page.title} description={page.description} keywords={page.keywords} schema={schema} minimal>
  <div class="font-sans">
  <section class="pt-32 pb-16 md:pt-44 md:pb-24">
    <div class="container max-w-4xl">
      <p class="mb-6 font-sans text-xs font-semibold uppercase tracking-widest text-primary">{page.eyebrow}</p>
      <h1 class="font-serif text-5xl font-extrabold leading-none tracking-tight text-on-surface md:text-7xl">
        {page.hero}
      </h1>
      <p class="mt-8 max-w-3xl font-sans text-xl leading-relaxed text-on-surface-variant">
        {page.intro}
      </p>
      <div class="mt-10 flex flex-col gap-4 sm:flex-row">
        <a
          href={SITE.appStoreUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-analytics="store_badge"
          data-analytics-label="Download on the App Store"
          data-analytics-placement={page.slug}
        >
          <img src="/app-store.svg" width={144} height={48} alt="Download Spendful on the App Store" class="h-12 w-auto" />
        </a>
        <a
          href={SITE.playStoreUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-analytics="store_badge"
          data-analytics-label="Get it on Google Play"
          data-analytics-placement={page.slug}
        >
          <img src="/play-store.svg" width={162} height={48} alt="Get Spendful on Google Play" class="h-12 w-auto" />
        </a>
      </div>
    </div>
  </section>

  <section class="bg-surface-container-low py-16 md:py-24">
    <div class="container grid gap-10 md:grid-cols-3">
      {page.sections.map((section) => (
        <article class="space-y-4">
          <h2 class="font-serif text-3xl font-bold tracking-tight text-on-surface">{section.heading}</h2>
          <p class="font-sans leading-relaxed text-on-surface-variant">{section.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="container max-w-4xl">
      <h2 class="font-serif text-4xl font-bold tracking-tight text-on-surface">Questions people ask</h2>
      <div class="mt-10 space-y-8">
        {page.faq.map((item) => (
          <article>
            <h3 class="font-sans text-xl font-semibold text-primary">{item.q}</h3>
            <p class="mt-3 font-sans leading-relaxed text-on-surface-variant">{item.a}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-primary py-16 text-on-primary md:py-24">
    <div class="container max-w-4xl text-center">
      <h2 class="font-serif text-4xl font-extrabold tracking-tight md:text-6xl">Start with one check-in.</h2>
      <p class="mx-auto mt-6 max-w-2xl font-sans text-lg text-on-primary/80">
        Spendful keeps spending awareness simple: no bank links, no heavy budgets, just a clearer record of where your money goes.
      </p>
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={SITE.appStoreUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-analytics="store_badge"
          data-analytics-label="Download on the App Store"
          data-analytics-placement={`${page.slug}-footer`}
        >
          <img src="/app-store.svg" width={144} height={48} alt="Download Spendful on the App Store" class="h-12 w-auto" />
        </a>
        <a
          href={SITE.playStoreUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-analytics="store_badge"
          data-analytics-label="Get it on Google Play"
          data-analytics-placement={`${page.slug}-footer`}
        >
          <img src="/play-store.svg" width={162} height={48} alt="Get Spendful on Google Play" class="h-12 w-auto" />
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: `${page.title} related Spendful pages`,
    itemListElement: [
      { '@type': 'ListItem', position: 1, url: absoluteUrl('/questions'), name: 'Spendful questions' },
      { '@type': 'ListItem', position: 2, url: absoluteUrl('/privacy'), name: 'Spendful privacy policy' },
      { '@type': 'ListItem', position: 3, url: absoluteUrl('/support'), name: 'Spendful support' },
    ],
  }).replace(/</g, '\\u003c')} />
  </div>
</Layout>

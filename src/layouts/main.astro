---
import '@/styles/global.css'
import Footer from '@/components/footer.astro'
import Header from '@/components/header.astro'

const { description, minimal, title } = Astro.props

const siteTitle = title ? `${title} — Spendful` : 'Spendful'
const siteDescription = description || 'Spendful is a calm, local-first spending journal. Track daily expenses with intention — no budgets, no stress, just gentle awareness of where your money goes.'
---

<html lang="en">
<head>
<script is:inline>if (localStorage.getItem('theme') === 'dark') document.documentElement.classList.add('dark')</script>
<meta charset="utf-8" />
<link rel="icon" type="image/svg+xml" href="/spendful-icon.icon/Assets/head-grow.svg" />
<meta name="viewport" content="width=device-width" />
<title>{siteTitle}</title>
<meta name="description" content={siteDescription} />
</head>
<body>
<main>
<Header minimal={minimal} />
<slot />
<Footer />
</main>
</body>
</html>

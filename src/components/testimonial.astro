---
import { Quote } from '@lucide/astro'
---

<section class="py-16 md:py-24 lg:py-32 bg-surface">
  <div class="container max-w-5xl">
    <div class="flex flex-col items-center gap-12 text-center">
      <Quote class="w-16 h-16 text-tertiary dark:text-primary opacity-20" />
      <blockquote class="font-serif text-4xl md:text-5xl font-light leading-tight text-on-surface italic before:content-['“'] after:content-['”']">It changed the way I think about money. Spendful isn’t just an app, it gave me breathing room in my financial life.</blockquote>
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
          <span class="font-serif font-bold text-primary text-lg">S</span>
        </div>
        <div class="text-left">
          <p class="font-serif font-bold text-on-surface">Sarah</p>
          <p class="text-xs text-on-surface-variant uppercase tracking-widest">★★★★★ App Store Review</p>
        </div>
      </div>
    </div>
  </div>
</section>

---
import { Leaf, ShieldCheck, Repeat } from '@lucide/astro'
---

<section class="py-32" id="circle">
  <div class="container max-w-5xl text-center space-y-16">
    <div class="space-y-6">
      <h2 class="font-serif text-5xl font-extrabold tracking-tight text-on-surface">Mindfulness over budgeting.</h2>
      <p class="text-xl text-on-surface-variant max-w-2xl mx-auto leading-relaxed">
        Traditional apps focus on restrictions. Spendful focuses on awareness. When you are aware of where your energy goes, balance occurs naturally.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 pt-10">
      {[
        { icon: Leaf, title: "Low Friction", desc: "Designed to be used for less than 60 seconds a day." },
        { icon: ShieldCheck, title: "Privacy First", desc: "Your data is yours. We never sell your personal narrative." },
        { icon: Repeat, title: "Sustainable Habit", desc: "Built on behavioral science to ensure long-term usage." }
      ].map((benefit, i) => (
        // motion
        // initial={{ opacity: 0, y: 20 }}
        // whileInView={{ opacity: 1, y: 0 }}
        // viewport={{ once: true }}
        // transition={{ delay: i * 0.2 }}
        <div
          class="space-y-6 group"
        >
          <div class="w-16 h-16 bg-surface-container-low rounded-full flex items-center justify-center mx-auto group-hover:bg-primary/10 transition-colors">
            <benefit.icon class="w-8 h-8 text-primary" />
          </div>
          <h4 class="font-serif text-xl font-bold">{benefit.title}</h4>
          <p class="text-on-surface-variant text-sm leading-relaxed">{benefit.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

---
import { Menu, Moon, Sun, X } from '@lucide/astro'

const { minimal } = Astro.props

const SECTIONS = ['Features', 'Benefits', 'Testimonials']
---

<header class="fixed top-0 z-50 border-b border-b-transparent w-full py-2 transition-all duration-300 md:py-6">
  <div class:list={['container flex items-center', minimal ? 'justify-center' : 'justify-between']}>
    <a href={minimal ? '/' : '#'} class="font-serif italic text-xl font-extrabold tracking-tighter text-primary md:text-2xl">
      Spendful
    </a>

    {!minimal && (
      <nav class="hidden md:flex items-center gap-12 lg:gap-32 xl:gap-40 text-lg font-medium">
        {SECTIONS.map((item) => (
          <a href={`#${item.toLowerCase()}`} class="text-on-surface-variant hover:text-primary transition-colors">
            {item}
          </a>
        ))}
      </nav>
      <div class="flex items-center gap-4">
        <button
          id="theme-toggle"
          aria-label="Toggle theme"
          class="size-10 rounded-full flex items-center justify-center bg-on-surface/5 hover:bg-on-surface/10 transition-colors text-on-surface"
        >
          <Moon class="icon-moon size-6" />
          <Sun class="icon-sun size-6" />
        </button>
        <a
          href="#download"
          data-analytics="cta"
          data-analytics-label="Begin Journey"
          data-analytics-placement="header"
          class="hidden md:block bg-primary bg-linear-to-b from-white/40 to-transparent dark:to-black/20 hover:bg-primary-container dark:hover:bg-primary/80 text-on-primary px-8 py-3 rounded-full text-sm font-medium transition-all shadow-xl shadow-primary/10 focus-visible:outline-primary"
        >
          Begin Journey
        </a>
        <button onclick="toggleMobileMenu()" aria-label="Toggle menu" class="toggle-menu -mx-3 p-3 md:hidden text-on-surface">
          <X class="icon-x" />
          <Menu class="icon-menu" />
        </button>
      </div>
    )}
  </div>

  <div class="menu md:hidden absolute top-full left-0 w-full bg-surface border-b border-on-surface/5 p-6 space-y-4 shadow-xl">
    {SECTIONS.map((item) => (
      <a href={`#${item.toLowerCase()}`} class="block text-md font-medium text-on-surface text-center">
        {item}
      </a>
    ))}
    <a
      href="#download"
      data-analytics="cta"
      data-analytics-label="Begin Journey"
      data-analytics-placement="mobile-menu"
      class="w-full bg-primary bg-linear-to-b from-white/40 to-transparent dark:to-black/20  text-on-primary py-4 rounded-xl font-medium text-center block"
    >
      Begin Journey
    </a>
  </div>
</header>

<style>
header {
  .icon-x {
    @apply hidden;
  }

  .icon-moon {
    @apply hidden;
  }

  &.open {
    .icon-x {
      @apply inline-block;
    }

    .icon-menu {
      @apply hidden;
    }
  }

  .menu {
    @apply opacity-0 invisible transition-[opacity,visibility,translate] duration-300;
    translate: 0 -1.25rem;

    &.show {
      @apply opacity-100 visible;
      translate: 0 0;
    }
  }
}

:global(html.dark) header {
  .icon-sun {
    @apply hidden;
  }

  .icon-moon {
    @apply inline-block;
  }
}
</style>

<script>
const header = document.querySelector('header')
const menuToggle = document.querySelector('header .toggle-menu')
const menu = document.querySelector('header .menu')
const themeToggle = document.getElementById('theme-toggle')

if (localStorage.getItem('theme') === 'dark') document.documentElement.classList.add('dark')

themeToggle?.addEventListener('click', function () {
  const isDark = document.documentElement.classList.toggle('dark')
  localStorage.setItem('theme', isDark ? 'dark' : 'light')
})

function calculateScroll() {
  const isScrolled = window.scrollY > 20

  if (isScrolled) {
    header.classList.add('glass')
  } else {
    header.classList.remove('glass')
  }
}

calculateScroll()

window.addEventListener('scroll', calculateScroll)

menuToggle?.addEventListener('click', function () {
  header.classList.toggle('open')
  menu.classList.toggle('show')
})

menu?.querySelectorAll('a').forEach(function (link) {
  link.addEventListener('click', function () {
    header.classList.remove('open')
    menu.classList.remove('show')
  })
})
</script>

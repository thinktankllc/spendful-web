---
import { Menu, X } from '@lucide/astro'
---

<nav class:list={['fixed top-0 z-50 w-full py-6 transition-all duration-300',
  /*isScrolled ? 'glass py-4' : 'bg-transparent py-6'*/
]}>
  <div class="max-w-7xl mx-auto px-6 md:px-8 flex justify-between items-center">
    <div class="font-serif italic text-xl font-extrabold tracking-tighter text-primary">
      The Mindful Editorial
    </div>

    <div class="hidden md:flex items-center gap-10 text-sm font-medium">
      {["Essence", "Flow", "Circle", "Journal"].map((item) => (
        <a
          href={`#${item.toLowerCase()}`}
          class="text-on-surface-variant hover:text-primary transition-colors"
        >
          {item}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-4">
      <button class="hidden sm:block bg-primary hover:bg-primary-container text-white px-8 py-3 rounded-full text-sm font-medium transition-all shadow-xl shadow-primary/10">
        Begin Journey
      </button>
      <button
        class="md:hidden text-on-surface"
      >
        <!--onClick setIsMobileMenuOpen(!isMobileMenuOpen)-->
        isMobileMenuOpen ? <X /> : <Menu />
      </button>
    </div>
  </div>

    <!--  isMobileMenuOpen -->
    <!--motion-->
    <!--initial={{ opacity: 0, y: -20 }}-->
    <!--animate={{ opacity: 1, y: 0 }}-->
    <div class="md:hidden absolute top-full left-0 w-full bg-white border-b border-on-surface/5 p-6 space-y-4 shadow-xl">
      {["Essence", "Flow", "Circle", "Journal"].map((item) => (
        <a
          href={`#${item.toLowerCase()}`}
          class="block text-lg font-medium text-on-surface"
        >
          onClick setIsMobileMenuOpen(false)
          {item}
        </a>
      ))}
      <button class="w-full bg-primary text-white py-4 rounded-xl font-medium">
        Begin Journey
      </button>
    </div>
</nav>

<script>
/*

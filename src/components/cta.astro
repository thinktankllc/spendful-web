---
---

<section class="py-16 md:py-24 lg:py-32 mt-28" id="download">
  <div class="container">
    <div class="background-gradient bg-primary-container bg-cover rounded-[3rem] py-16 px-8 md:p-24 flex flex-col items-center text-center space-y-10 relative overflow-hidden">
      <div class="absolute top-0 left-0 backdrop-blur-[100px] saturate-150 size-full" />
      <h2 class="font-serif text-5xl md:text-7xl font-extrabold text-on-primary-container tracking-tighter leading-tight z-10">
        A calmer way to track<br /><span class="italic">your spending.</span>
      </h2>
      <p class="text-on-primary-container/80 text-xl max-w-xl z-10 font-light">
        Free to download. Start your daily practice today.
      </p>
      <div class="flex items-center gap-4 sm:gap-6 z-10">
        <a href="https://apps.apple.com/app/id6757114071" target="_blank" rel="noopener noreferrer">
          <img
            src="/app-store.svg"
            width={144}
            height={48}
            alt="Download on the App Store"
            class="w-auto h-12"
          />
        </a>
        <a href="https://play.google.com/store/apps/details?id=com.spendful.app" target="_blank" rel="noopener noreferrer">
          <img
            src="/play-store.svg"
            width={162}
            height={48}
            alt="Get it on Google Play"
            class="w-auto h-12"
          />
        </a>
      </div>
    </div>
  </div>
</section>

<style>
.background-gradient {
  background-image:
    linear-gradient(to bottom, transparent 20%, color-mix(in oklab, var(--color-black) 80%, transparent)),
    url(/apple-touch-icon.png);
  background-position: 50%;
}

h2 {
  text-shadow: 0 1px black;
}
</style>

<section class="py-32" id="journal">
  <div class="container">
    <div class="bg-primary-container rounded-[3rem] py-16 px-8 md:p-24 flex flex-col items-center text-center space-y-10 relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full h-full opacity-10 pointer-events-none">
        <div class="absolute top-0 right-0 w-96 h-96 bg-white blur-[150px]"></div>
      </div>
      <h2 class="font-serif text-5xl md:text-7xl font-extrabold text-on-primary-container tracking-tighter leading-none z-10">
        Ready for financial <br /><span class="italic">serenity?</span>
      </h2>
      <p class="text-on-primary-container/80 text-xl max-w-xl z-10 font-light">
        Join 50,000+ individuals who have found a better way to relate to their wealth.
      </p>
      <div class="flex flex-col items-center sm:flex-row gap-6 z-10">
        <a href="https://apps.apple.com/app/id6757114071" target="_blank" rel="noopener noreferrer">
          <img
            src="/app-store.svg"
            width={144}
            height={48}
            alt="Download on the App Store"
            class="w-auto h-12"
          />
        </a>
        <a href="https://play.google.com/store/apps/details?id=com.spendful.app" target="_blank" rel="noopener noreferrer">
          <img
            src="/play-store.svg"
            width={162}
            height={48}
            alt="Get it on Google Play"
            class="w-auto h-12"
          />
        </a>
      </div>
    </div>
  </div>
</section>

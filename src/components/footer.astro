---
const LINKS = [
  { label: 'Privacy Policy', href: '/privacy' },
  { label: 'Support', href: '/support' },
]
---

<footer class="w-full py-16 px-6 md:px-8 bg-surface-container-low">
  <div class="flex flex-col md:flex-row justify-between items-center max-w-7xl mx-auto gap-8">
    <a href="/" class="font-serif italic text-lg font-bold tracking-tighter text-primary">
      The Mindful Editorial
    </a>
    <div class="flex flex-wrap justify-center gap-8 text-xs uppercase tracking-widest text-on-surface-variant">
      {LINKS.map((link) => (
        <a href={link.href} class="hover:text-primary transition-colors">{link.label}</a>
      ))}
    </div>
    <p class="text-xs uppercase tracking-widest text-on-surface-variant/60 text-center md:text-right">
      © 2024 The Mindful Editorial. Sanctuary for Financial Awareness.
    </p>
  </div>
</footer>

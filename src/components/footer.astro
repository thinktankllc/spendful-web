---
const GROUPS = [
  {
    heading: 'Legal',
    links: [
      { label: 'Terms of Use', href: '/terms' },
      { label: 'Privacy Policy', href: '/privacy' },
    ],
  },
  {
    heading: 'Help',
    links: [
      { label: 'Questions', href: '/questions' },
      { label: 'Support', href: '/support' },
    ],
  },
]
---

<footer class="w-full bg-surface-container-low">
  <div class="container py-8 md:py-16 grid md:grid-rows-2 md:grid-cols-2 gap-8 md:gap-y-2">
    <div class="max-md:text-center">
      <a href="/" class="font-serif italic text-xl font-bold tracking-tighter text-primary">
        Spendful
      </a>
    </div>
    <div class="row-span-2 grid grid-cols-2 gap-8">
      {GROUPS.map((group) => (
        <div class="flex flex-col justify-end gap-4 first:max-md:items-end">
          <p class="text-xs uppercase tracking-widest text-on-surface-variant/40">{group.heading}</p>
          {group.links.map((link) => (
            <a
              href={link.href}
              class="block text-xs uppercase tracking-widest text-on-surface-variant"
            >
              {link.label}
            </a>
          ))}
        </div>
      ))}
    </div>
    <p class="max-md:text-center text-xs/relaxed uppercase tracking-widest text-on-surface-variant/60">
      © 2026 Spendful<br/>Sanctuary for Financial Awareness
    </p>
  </div>
</footer>

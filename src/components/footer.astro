---
const GROUPS = [
  {
    heading: 'Learn',
    links: [
      { label: 'About', href: '/about' },
      { label: 'No Bank Links', href: '/spending-tracker-without-bank-account' },
      { label: 'Privacy First', href: '/privacy-first-expense-tracker' },
    ],
  },
  {
    heading: 'Legal',
    links: [
      { label: 'Terms of Use', href: '/terms' },
      { label: 'Privacy Policy', href: '/privacy' },
    ],
  },
  {
    heading: 'Help',
    links: [
      { label: 'Questions', href: '/questions' },
      { label: 'Support', href: '/support' },
    ],
  },
]
---

<footer class="w-full bg-surface-container-low">
  <div class="container py-8 md:py-16 grid grid-cols-2 lg:grid-cols-12 gap-8">
    <div class="lg:col-span-6">
      <a href="/" class="font-serif italic text-xl font-bold tracking-tighter text-primary">
        Spendful
      </a>
      <p class="mt-4 lg:mt-6 text-xs/loose uppercase tracking-widest text-on-surface-variant/60">
        &copy; 2026 Spendful<br/>Sanctuary for Financial Awareness
      </p>
    </div>
    {GROUPS.map((group) => (
      <div class="lg:col-span-2 flex flex-col gap-4">
        <p class="text-xs uppercase tracking-widest text-on-surface-variant/40">{group.heading}</p>
        {group.links.map((link) => (
          <a
            href={link.href}
            class="block text-xs uppercase tracking-widest text-on-surface-variant"
          >
            {link.label}
          </a>
        ))}
      </div>
    ))}
  </div>
</footer>

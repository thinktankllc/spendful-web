---
import { Image } from 'astro:assets'
import { Sparkles, ShieldCheck, Lock, Download } from '@lucide/astro'

import screenMonth from '@/assets/screen-month.png'
import screenMonthDark from '@/assets/screen-month-dark.png'
---

<section class="pt-28 md:pt-40 pb-16 md:pb-24 overflow-hidden">
  <div class="container grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <!--motion-->
<!--
    initial={{ opacity: 0, x: -50 }}
    whileInView={{ opacity: 1, x: 0 }}
    viewport={{ once: true }}
    transition={{ duration: 0.8 }}
-->
    <div class="space-y-10 max-lg:text-center">
      <div class="inline-flex items-center gap-3 bg-primary/10 px-4 py-2 rounded-full">
        <Sparkles class="w-4 h-4 text-primary" />
        <span class="text-xs font-semibold uppercase tracking-widest text-primary">Spendful — Mindful Spending</span>
      </div>

      <h1 class="font-serif text-6xl md:text-8xl font-extrabold tracking-tighter leading-[0.9] text-on-surface">
        Know where your <br />
        <span class="text-primary italic">money goes.</span>
      </h1>

      <p class="text-xl text-on-surface-variant max-w-lg leading-relaxed font-light max-lg:mx-auto">
        One simple daily check-in. No budgets, no bank links, just a clearer sense of your spending.
      </p>

      <div class="flex flex-col gap-3 max-lg:items-center">
        <span class="flex items-center gap-2 text-md text-on-surface-variant">
          <Download class="w-4 h-4 text-primary shrink-0" />
          Free to download
        </span>
        <span class="flex items-center gap-2 text-md text-on-surface-variant">
          <ShieldCheck class="w-4 h-4 text-primary shrink-0" />
          No account needed
        </span>
        <span class="flex items-center gap-2 text-md text-on-surface-variant">
          <Lock class="w-4 h-4 text-primary shrink-0" />
          Data stays on your device
        </span>
      </div>

      <div class="flex items-center gap-4 pt-4 max-sm:justify-between sm:justify-center lg:justify-start sm:gap-6">
        <a href="https://apps.apple.com/app/id6757114071" target="_blank" rel="noopener noreferrer">
          <img
            src="/app-store.svg"
            width={144}
            height={48}
            alt="Download on the App Store"
            class="w-auto h-16 sm:h-12"
          />
        </a>
        <a href="https://play.google.com/store/apps/details?id=com.spendful.app" target="_blank" rel="noopener noreferrer">
          <img
            src="/play-store.svg"
            width={162}
            height={48}
            alt="Get it on Google Play"
            class="w-auto h-16 sm:h-12"
          />
        </a>
      </div>
    </div>

    <!--motion-->
<!--
    initial={{ opacity: 0, scale: 0.8 }}
    whileInView={{ opacity: 1, scale: 1 }}
    viewport={{ once: true }}
    transition={{ duration: 1, ease: "easeOut" }}
-->
    <div class="relative flex justify-center">
      <div class="relative z-10 w-full max-w-sm aspect-[9/19] bg-surface-container-lowest rounded-[3rem] p-3 shadow-2xl ring-8 ring-on-surface/5 overflow-hidden">
        <Image
          src={screenMonth}
          width={1320}
          height={2868}
          alt="Spendful App Interface"
          widths={[360, 540, 720]}
          priority
          class="size-full object-cover rounded-[2.2rem] dark:hidden"
        />
        <Image
          src={screenMonthDark}
          width={1320}
          height={2868}
          alt="Spendful App Interface"
          widths={[360, 540, 720]}
          priority
          class="size-full object-cover rounded-[2.2rem] not-dark:hidden"
        />
      </div>
      <div class="absolute -top-12 -right-12 w-64 h-64 bg-primary/10 rounded-full blur-[100px] -z-10"></div>
      <div class="absolute -bottom-12 -left-12 w-64 h-64 bg-tertiary/10 rounded-full blur-[100px] -z-10"></div>
    </div>
  </div>
</section>
